{
  "name": "@grontis/gcanvas",
  "version": "0.3.0",
  "description": "An Angular 19 no-code canvas editor library. Ships a bare drag/resize/rich-text canvas (<gc-canvas>) and a full editor shell (<gc-canvas-editor>) with palette, layers, inspector, command palette, responsive preview, and an HTML/CSS export pipeline.",
  "keywords": [
    "angular",
    "angular-library",
    "canvas",
    "editor",
    "no-code",
    "low-code",
    "drag-and-drop",
    "rich-text",
    "tiptap",
    "page-builder",
    "wysiwyg",
    "responsive"
  ],
  "author": "grontis <grantkveton@msn.com>",
  "license": "MIT",
  "homepage": "https://github.com/grontis/gcanvas#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grontis/gcanvas.git",
    "directory": "projects/gcanvas"
  },
  "bugs": {
    "url": "https://github.com/grontis/gcanvas/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@angular/cdk": ">=19.0.0",
    "@angular/common": ">=19.0.0",
    "@angular/core": ">=19.0.0",
    "@tiptap/core": ">=2.0.0",
    "@tiptap/extension-color": ">=2.0.0",
    "@tiptap/extension-text-style": ">=2.0.0",
    "@tiptap/extension-font-family": ">=2.0.0",
    "@tiptap/extension-highlight": ">=2.0.0",
    "@tiptap/extension-link": ">=2.0.0",
    "@tiptap/extension-text-align": ">=2.0.0",
    "@tiptap/extension-underline": ">=2.0.0",
    "@tiptap/html": ">=2.0.0",
    "@tiptap/starter-kit": ">=2.0.0",
    "ngx-tiptap": ">=9.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": false
}
